---
// About page. Ported from the Phase 0 #about-section: the "Why we are different"
// narrative, the trust badges, and the four values. Footer/Nav come from
// BaseLayout, so the duplicated Phase 0 <footer> is intentionally dropped.
// The page-specific .about-* / .value-* / .trust-* styles are not in global.css,
// so they live in the scoped <style> block below (Astro auto-scopes them).
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="About | Intelligent Carpet Cleaning, Cheltenham"
  description="Cheltenham carpet cleaning specialists who match method to fibre. Honest pricing, real technical knowledge, and a local team across Gloucestershire."
>
  <section class="about-page">
    <div class="about-hero">
      <h1>About Intelligent Carpet Cleaning</h1>
      <p>Cheltenham-based carpet specialists combining genuine expertise with modern technology to deliver results that last.</p>
    </div>
    <div class="about-content">
      <div class="about-text">
        <h2>Why we are different</h2>
        <p>Most carpet cleaning companies treat every floor the same. We do not. Every carpet has a different fibre type, pile construction, and soiling profile. Getting that wrong damages the carpet, sometimes permanently.</p>
        <p>We built our AI assistant because we were tired of customers being misled by rental machines and cut-price operators. Our AI explains what your carpet actually needs before anyone steps through your door, so there are no surprises on the day and no damage after the fact.</p>
        <p>Based in Cheltenham, we serve the full Gloucestershire area for both residential and commercial clients.</p>
        <!-- TODO(trust-stats): reinstate quantified track-record metrics only when
             substantiated (a real completed-job count or verified review rating).
             No fabricated figures (ASA/CAP, L-009). Tiles below are capability facts. -->
        <div class="trust-badges">
          <div class="trust-badge"><div class="trust-badge-num">15+</div><div class="trust-badge-label">Fibre Types</div></div>
          <div class="trust-badge"><div class="trust-badge-num">6</div><div class="trust-badge-label">Days a Week</div></div>
          <div class="trust-badge"><div class="trust-badge-num">10%</div><div class="trust-badge-label">Deposit to Book</div></div>
        </div>
      </div>
      <div class="about-values">
        <div class="value-item"><div class="value-icon">🔬</div><div><div class="value-title">Technical knowledge first</div><div class="value-desc">We identify fibre type, pile construction, and soiling category before selecting any cleaning method. This is not standard practice in the industry.</div></div></div>
        <div class="value-item"><div class="value-icon">💬</div><div><div class="value-title">Transparent pricing</div><div class="value-desc">Our AI explains exactly why a clean costs what it costs. No vague estimates, no upselling on arrival.</div></div></div>
        <div class="value-item"><div class="value-icon">🛡️</div><div><div class="value-title">Honest about limitations</div><div class="value-desc">Some stains are permanent. Some damage is irreversible. We will always tell you the truth rather than take your money for a job that cannot be done.</div></div></div>
        <div class="value-item"><div class="value-icon">📍</div><div><div class="value-title">Local and accountable</div><div class="value-desc">We are based in Cheltenham and serve Gloucestershire. If something is not right, you speak to us directly, not a call centre.</div></div></div>
      </div>
    </div>
    <div class="about-cta">
      <h2 class="about-cta-title">Ready for a carpet clean done properly?</h2>
      <p class="about-cta-sub">Get an instant, fully explained quote and book a visit in minutes. No callbacks, no surprises.</p>
      <a class="btn-primary" href="/book">Get a Quote &amp; Book</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Ported from the Phase 0 single-page site's #about-section styles.
     Scoped to this page by Astro. The shared --vars come from global.css. */
  .about-page { padding-top: 70px; }

  .about-hero {
    background: linear-gradient(135deg, var(--navy-dark), var(--navy));
    padding: 4rem 2rem;
    text-align: center;
  }
  .about-hero h1 {
    font-family: "Raleway", sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 0.75rem;
  }
  .about-hero p {
    color: rgba(255, 255, 255, 0.65);
    font-size: 1rem;
    font-weight: 300;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .about-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .about-text h2 {
    font-family: "Raleway", sans-serif;
    font-size: 1.7rem;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 1rem;
  }
  .about-text p {
    color: var(--text-mid);
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .about-values {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .value-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.25rem;
    background: var(--off-white);
    border-radius: 10px;
    border-left: 3px solid var(--teal);
  }
  .value-icon {
    font-size: 1.4rem;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .value-title {
    font-family: "Raleway", sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 0.3rem;
  }
  .value-desc {
    font-size: 0.85rem;
    color: var(--text-mid);
    line-height: 1.6;
  }

  .trust-badges {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }
  .trust-badge {
    text-align: center;
    padding: 1.25rem 0.75rem;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 10px;
  }
  .trust-badge-num {
    font-family: "Raleway", sans-serif;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--teal);
  }
  .trust-badge-label {
    font-size: 0.75rem;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Closing call-to-action — new for the standalone page. */
  .about-cta {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem 5rem;
    text-align: center;
  }
  .about-cta-title {
    font-family: "Raleway", sans-serif;
    font-size: 1.7rem;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 0.75rem;
  }
  .about-cta-sub {
    font-size: 1rem;
    color: var(--text-mid);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 auto 2rem;
  }

  @media (max-width: 768px) {
    .about-hero h1 { font-size: 2rem; }
    .about-content { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
