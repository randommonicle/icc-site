---
// Care-guide template. One template renders every guide in the `guides`
// collection (D-006). It pulls title/description/FAQ from frontmatter, renders
// the Markdown body, and emits Article + FAQPage JSON-LD into the <head> via
// BaseLayout's head slot. Article styling is scoped here and applied to the
// Markdown output with :global(), mirroring the history page's reading column.
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  return guides.map((guide) => ({ params: { slug: guide.id }, props: { guide } }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const { title, description, faq, updated } = guide.data;

const siteUrl = (Astro.site?.href ?? 'https://www.intelligentclean.co.uk/').replace(/\/$/, '');
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
// Format with timeZone:UTC so the build's UTC runtime can't shift the month
// (the L-005 lesson, applied to display dates as well as job-card dates).
const updatedLabel = new Date(updated).toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  timeZone: 'UTC',
});

// Article structured data — authored and published by ICC.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: pageUrl,
  mainEntityOfPage: pageUrl,
  dateModified: updated,
  author: { '@type': 'Organization', name: 'Intelligent Carpet Cleaning', url: siteUrl },
  publisher: {
    '@type': 'Organization',
    name: 'Intelligent Carpet Cleaning',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/logo.jpg` },
  },
};

// FAQ structured data — only when the guide defines questions. Mirrors the
// visible FAQ below so the markup matches the rendered page.
const faqSchema = faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    }
  : null;

// Breadcrumb: Home › Care Guides › this guide.
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Care Guides', item: `${siteUrl}/guides/` },
    { '@type': 'ListItem', position: 3, name: title, item: pageUrl },
  ],
};
---
<BaseLayout title={`${title} | Intelligent Carpet Cleaning`} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <section class="guide-page">
    <div class="guide-hero">
      <div class="section-label guide-hero-label"><a href="/guides">Care Guides</a></div>
      <h1>{title}</h1>
      <p class="guide-updated">Last updated {updatedLabel}</p>
    </div>

    <article class="guide-article">
      <div class="guide-body">
        <Content />
      </div>

      {faq.length > 0 && (
        <section class="guide-faq">
          <h2 class="section-title">Frequently asked questions</h2>
          {faq.map((f) => (
            <div class="guide-faq-item">
              <h3>{f.question}</h3>
              <p>{f.answer}</p>
            </div>
          ))}
        </section>
      )}

      <div class="guide-cta">
        <h2 class="guide-cta-title">Not sure what your carpet needs?</h2>
        <p class="guide-cta-sub">Our AI assistant identifies the fibre, tells you honestly what can and cannot be cleaned, and gives you an itemised quote before we ever step through your door.</p>
        <a class="btn-primary" href="/book">Get an Instant Quote</a>
      </div>
    </article>
  </section>
</BaseLayout>

<style>
  /* Page-specific styling for the guide reading column. Scoped by Astro;
     shared design tokens come from global.css. Markdown output is styled with
     :global() because those elements are rendered by <Content/>, not authored
     in this component. */
  .guide-page { padding-top: 70px; }

  .guide-hero {
    background: linear-gradient(135deg, var(--navy-dark), var(--navy));
    padding: 4rem 2rem 3rem;
    text-align: center;
  }
  .guide-hero-label { margin-bottom: 0.75rem; }
  .guide-hero-label a { color: var(--teal-light); text-decoration: none; }
  .guide-hero-label a:hover { text-decoration: underline; }
  .guide-hero h1 {
    font-family: "Raleway", sans-serif;
    font-size: 2.4rem;
    font-weight: 800;
    color: #fff;
    margin: 0 auto;
    max-width: 760px;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }
  .guide-updated {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.78rem;
    margin-top: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .guide-article { max-width: 760px; margin: 0 auto; padding: 3.5rem 2rem 1rem; }

  .guide-body :global(h2) {
    font-family: "Raleway", sans-serif;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--navy);
    margin: 2.75rem 0 1rem;
    letter-spacing: -0.01em;
  }
  .guide-body :global(h2:first-child) { margin-top: 0; }
  .guide-body :global(h3) {
    font-family: "Raleway", sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--navy);
    margin: 1.75rem 0 0.6rem;
  }
  .guide-body :global(p) {
    color: var(--text-mid);
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 1.1rem;
  }
  .guide-body :global(ul),
  .guide-body :global(ol) {
    color: var(--text-mid);
    font-size: 1rem;
    line-height: 1.8;
    margin: 0 0 1.2rem 1.5rem;
  }
  .guide-body :global(li) { margin-bottom: 0.5rem; }
  .guide-body :global(strong) { color: var(--navy); font-weight: 700; }
  .guide-body :global(a) { color: var(--teal); }
  .guide-body :global(blockquote) {
    border-left: 3px solid var(--teal);
    padding-left: 1rem;
    margin: 0 0 1.2rem;
    color: var(--text-light);
    font-style: italic;
  }

  .guide-faq {
    margin-top: 3rem;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }
  .guide-faq .section-title { font-size: 1.5rem; margin-bottom: 1.5rem; }
  .guide-faq-item { margin-bottom: 1.5rem; }
  .guide-faq-item h3 {
    font-family: "Raleway", sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 0.4rem;
  }
  .guide-faq-item p { color: var(--text-mid); font-size: 0.97rem; line-height: 1.75; }

  .guide-cta {
    margin: 3.5rem 0 4rem;
    padding: 2.5rem 2rem;
    background: var(--off-white);
    border: 1px solid var(--border);
    border-top: 3px solid var(--teal);
    border-radius: 12px;
    text-align: center;
  }
  .guide-cta-title {
    font-family: "Raleway", sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 0.75rem;
  }
  .guide-cta-sub {
    font-size: 0.95rem;
    color: var(--text-mid);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto 1.75rem;
  }

  @media (max-width: 768px) {
    .guide-hero h1 { font-size: 1.9rem; }
    .guide-article { padding-top: 2.5rem; }
    .guide-body :global(h2) { font-size: 1.4rem; }
  }
</style>
