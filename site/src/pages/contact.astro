---
// Contact page. Ports the contact-info-card and area-coverage block from the
// Phase 0 index.html book-section. Bookings run through the AI assistant, so the
// primary call to action points at /book. Page-specific CSS is scoped below.
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---
<BaseLayout
  title="Contact | Intelligent Carpet Cleaning, Cheltenham"
  description="Contact Intelligent Carpet Cleaning, Cheltenham. Call 01242 279590 or book through our AI assistant. Covering Gloucestershire, Monday to Saturday."
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <div class="section-label" style="color:var(--teal-light);">Get in Touch</div>
      <h1>Contact Us</h1>
      <p>Based in Cheltenham and covering the wider Gloucestershire area. Reach us by phone or email, or book your clean instantly through our AI assistant.</p>
    </div>
  </section>

  <div class="contact-layout">
    <div class="contact-info-card">
      <div class="contact-block">
        <div class="contact-icon"><Icon name="map-pin" color="var(--teal)" /></div>
        <div>
          <div class="contact-label">Service Area</div>
          <div class="contact-value">Cheltenham and Gloucestershire</div>
        </div>
      </div>
      <div class="contact-block">
        <div class="contact-icon"><Icon name="phone" color="var(--teal)" /></div>
        <div>
          <div class="contact-label">Phone</div>
          <div class="contact-value"><a href="tel:01242279590">01242 279590</a></div>
        </div>
      </div>
      <div class="contact-block">
        <div class="contact-icon"><Icon name="mail" color="var(--teal)" /></div>
        <div>
          <div class="contact-label">Email</div>
          <div class="contact-value"><a href="mailto:hello@intelligentclean.co.uk">hello@intelligentclean.co.uk</a></div>
        </div>
      </div>
      <div class="contact-block">
        <div class="contact-icon"><Icon name="clock" color="var(--teal)" /></div>
        <div>
          <div class="contact-label">Operating Hours</div>
          <div class="contact-value">Monday to Saturday, 8am to 6pm</div>
        </div>
      </div>
      <div class="area-coverage">
        <h3>Areas Covered</h3>
        <div class="area-tags">
          <div class="area-tag">Cheltenham</div>
          <div class="area-tag">Gloucester</div>
          <div class="area-tag">Cirencester</div>
          <div class="area-tag">Stroud</div>
          <div class="area-tag">Tewkesbury</div>
          <div class="area-tag">Winchcombe</div>
          <div class="area-tag">Bishops Cleeve</div>
          <div class="area-tag">Charlton Kings</div>
          <div class="area-tag">Prestbury</div>
        </div>
      </div>
    </div>

    <div class="contact-booking">
      <h2>Book through our AI assistant</h2>
      <p>All bookings are taken through our AI chat assistant. It gives you an instant quote, recommends the right cleaning method for your carpets, and confirms an appointment slot in a few minutes. You will receive a confirmation email the moment your slot is booked.</p>
      <p>Prefer to speak to a person? Call <a href="tel:01242279590">01242 279590</a> or email <a href="mailto:hello@intelligentclean.co.uk">hello@intelligentclean.co.uk</a> and we will be glad to help.</p>
      <a class="btn-primary" href="/book">Start a Booking Chat</a>
    </div>
  </div>
</BaseLayout>

<style>
  /* Page header band — ports the .about-hero / .book-hero dark gradient from the
     Phase 0 index.html so this page matches the rest of the site. */
  .page-hero {
    background: linear-gradient(135deg, var(--navy-dark), var(--navy));
    padding: 4rem 2rem;
    margin-top: 70px; /* clear the fixed nav */
  }
  .page-hero-inner { max-width: 1100px; margin: 0 auto; }
  .page-hero h1 {
    font-family: "Raleway", sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: #fff;
    margin: 0.5rem 0 0.75rem;
    letter-spacing: -0.02em;
  }
  .page-hero p {
    color: rgba(255, 255, 255, 0.65);
    font-size: 1rem;
    font-weight: 300;
    max-width: 640px;
    line-height: 1.7;
  }

  /* Two-column layout: contact details + booking note */
  .contact-layout {
    max-width: 1000px;
    margin: 0 auto;
    padding: 4rem 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* Contact details column — ported from index.html .contact-info-card */
  .contact-info-card { display: flex; flex-direction: column; gap: 1.25rem; }
  .contact-block {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .contact-icon {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    background: rgba(26, 138, 122, 0.1);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
  }
  .contact-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--teal);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.3rem;
  }
  .contact-value { font-size: 0.9rem; color: var(--text-dark); }
  .contact-value a { color: inherit; text-decoration: none; }
  .contact-value a:hover { color: var(--teal); }

  /* Areas covered — ported from index.html .area-coverage */
  .area-coverage {
    background: linear-gradient(135deg, var(--navy), var(--teal));
    border-radius: 12px;
    padding: 1.5rem;
    color: #fff;
  }
  .area-coverage h3 {
    font-family: "Raleway", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .area-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .area-tag {
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 100px;
    padding: 0.25rem 0.75rem;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.9);
  }

  /* Booking note column */
  .contact-booking {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 2px 20px rgba(12, 44, 37, 0.08);
  }
  .contact-booking h2 {
    font-family: "Raleway", sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 1rem;
  }
  .contact-booking p {
    font-size: 0.95rem;
    color: var(--text-mid);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .contact-booking a { color: var(--teal); text-decoration: none; font-weight: 700; }
  .contact-booking a:hover { text-decoration: underline; }
  .contact-booking .btn-primary {
    margin-top: 0.75rem;
    color: #fff;
    text-decoration: none;
    font-weight: 700;
  }
  .contact-booking .btn-primary:hover { text-decoration: none; }

  @media (max-width: 820px) {
    .page-hero h1 { font-size: 2rem; }
    .contact-layout { grid-template-columns: 1fr; }
  }
</style>
