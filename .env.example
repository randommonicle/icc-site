# Environment variables required by the ICC site
# Copy this file to .env for local dev, OR set each value in
# Netlify dashboard -> Site settings -> Environment variables.
# Do NOT commit the real .env file (it is in .gitignore).

# ====== REQUIRED ======

# Anthropic API key for the AI chat assistant.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Resend API key for sending booking confirmation emails.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# LEGACY (Slice 5d): the admin dashboard now signs in with Supabase Auth (per-user
# email + password), so /api/bookings and /api/handoffs no longer read ADMIN_SECRET.
# It is unused by the app and can be removed from Netlify once 5d is confirmed live.
# Kept here only as a record; do not rely on it for admin access.
ADMIN_SECRET=unused-since-slice-5d

# Netlify Blobs auth — only needed because drag-and-drop deploys
# do not auto-configure Blobs context. Find these at:
#   https://app.netlify.com/  ->  User settings -> Applications -> New personal token
#   Site ID: Netlify dashboard -> Site settings -> Site details
NETLIFY_SITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NETLIFY_TOKEN=nfp_xxxxxxxxxxxxxxxx

# ====== SUPABASE (operational backend — Slice 5) ======

# Hosted ICC project "icc-platform" (ref qzcfgpfvzpynnjgriqqn, ICC org, London).
# Server-side ONLY: the service-role key bypasses Row Level Security, so it must
# never reach the browser (D-009 secrets rule).
# Optional for now and fail-open: when EITHER value is unset the functions skip
# the Supabase write (escalations still email Mark, the guaranteed path) and the
# human_handoff INSERT is a no-op. Set BOTH in Netlify to enable the live INSERT
# (Slice 5a, sign-off-gated — it changes live behaviour the moment they are set).
# Find both here (Project URL + the secret service_role key):
#   https://supabase.com/dashboard/project/qzcfgpfvzpynnjgriqqn/settings/api
SUPABASE_URL=https://qzcfgpfvzpynnjgriqqn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_secret_xxxxxxxx

# Admin auth (Slice 5d). The admin dashboard signs in with Supabase Auth
# (email + password). Public sign-ups are DISABLED in the project, so only the
# operators created in the dashboard exist.
#   ADMIN_EMAILS: comma-separated server-side allowlist of admin emails (defence
#     in depth on top of disabled signups). Optional — defaults to the two
#     operators (mark_director@ + ben@). Set in Netlify if the admin set changes.
#   SUPABASE_PUBLISHABLE_KEY: the PUBLIC publishable (anon) key used to verify
#     admin session tokens server-side and to sign in from admin.html. Optional —
#     the code carries the current value as a fallback (it is not a secret). Set
#     only to rotate it. Find it at the same API settings page as the URL above.
# ADMIN_EMAILS=mark_director@intelligentclean.co.uk,ben@intelligentclean.co.uk
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Bookings backend switch (Slice 5b, D-021). When set to exactly "postgres" AND
# both SUPABASE_* above are set, confirm_booking writes to the Supabase `jobs`
# table, availability derives from it, and the hardened 09:00-16:30 trading hours
# apply. Unset (or any other value) keeps the Phase 0 Netlify Blobs path,
# byte-identical. This is the deliberate enablement switch AND the rollback:
# unset it (and redeploy) to revert bookings to Blobs. Leave UNSET until the
# sign-off moment. If it is "postgres" but a SUPABASE_* value is missing, the
# functions log a warning and fall back to Blobs.
BOOKINGS_STORE=

# ====== OPTIONAL ======

# Email sender/recipient overrides (live values live in Netlify; these mirror them).
# OPERATOR_EMAIL must be Mark's REAL Workspace mailbox: it is mark_director@, NOT
# mark@ — mark@ was never created, so sending to it hard-bounced and Resend-suppressed
# it, silently dropping every operator email (see LESSONS_LEARNED L-015). From-addresses
# send from the Resend-verified domain (they need not be real mailboxes to send).
# Defaults (used when unset) keep things working in Resend's sandbox:
#   OPERATOR_EMAIL  = ben.graham240689@gmail.com
#   OPERATOR_FROM   = ICC Bookings <onboarding@resend.dev>
#   CUSTOMER_FROM   = Intelligent Carpet Cleaning <onboarding@resend.dev>
OPERATOR_EMAIL=mark_director@intelligentclean.co.uk
OPERATOR_FROM=ICC Bookings <bookings@intelligentclean.co.uk>
CUSTOMER_FROM=Intelligent Carpet Cleaning <hello@intelligentclean.co.uk>

# Origin allowlist for /api/chat (comma-separated). When set, the chat
# endpoint will 403 any request that did not come from one of these
# origins. When NOT set, the function auto-derives the allowlist from
# Netlify's URL / DEPLOY_URL env vars and fails OPEN on a miss (the
# per-IP rate limit is the real defence). Only set this if you want
# strict enforcement.
# ALLOWED_ORIGINS=https://intelligentclean.co.uk,https://www.intelligentclean.co.uk
